{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: Debug (All Platforms)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--dart-define", "APP_ENV=dev"
      ]
    },
    {
      "name": "Flutter: Profile (All Platforms)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "Flutter: Release (All Platforms)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    },
    {
      "name": "Flutter: macOS (Debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "macos"
    },
    {
      "name": "Flutter: Web (Debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome"
    }
  ]
}
